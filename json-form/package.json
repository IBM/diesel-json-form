{
  "name": "@diesel-parser/json-form",
  "version": "7.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "module": "dist/index.js",
  "dependencies": {
    "@diesel-parser/json-schema-facade-ts": "^0.17.0",
    "i18next": "^20.6.1"
  },
  "peerDependencies": {
    "@carbon/icon-helpers": "^10.76.0",
    "@carbon/icons": "^11.79.0",
    "@carbon/styles": "^1.105.0",
    "@carbon/web-components": "^2.53.0"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "npm-scripts-watcher": "^1.0.2",
    "rimraf": "^6.0.1",
    "sass": "^1.81.0",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "npm run clean && npm run lint && npm run build:ts && npm run test && npm run build:sass",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "build:sass-dev": "sass --source-map --load-path=../node_modules/ scss/JsonForm.scss dist/JsonForm.css",
    "build:sass": "sass --style=compressed --load-path=../node_modules/ scss/JsonForm.scss dist/JsonForm.css",
    "clean": "rimraf dist",
    "test": "vitest --run",
    "watch": "npm-scripts-watcher",
    "prettify": "prettier --write .",
    "lint": "eslint '**/*.{js,ts,tsx}'",
    "lint:fix": "eslint '**/*.{js,ts,tsx}' --fix"
  },
  "watch": {
    "src/**/!(*.test|*.spec).{ts,tsx}": [
      "build:ts"
    ],
    "scss/**/*.scss": [
      "build:sass"
    ]
  }
}
