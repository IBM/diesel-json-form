{
    "compilerOptions": {
        "target": "es6",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "inlineSources": true,
        "inlineSourceMap": true,
        "strict": true,
        "module": "esnext",
        "outDir": "dist",
        "declaration": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "Node",
        "resolveJsonModule": true,
        "jsx": "react",
        "jsxFactory": "createDomElement",
        "jsxFragmentFactory": "createDomElement"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}